# ═══════════════════════════════════════════════════════════════════
#  MyProx — Production Environment Variables
#  cp .env.production.example .env.production
#  NEVER commit .env.production to git !
# ═══════════════════════════════════════════════════════════════════

# ── Postgres ────────────────────────────────────────────────────────
POSTGRES_DB=myprox
POSTGRES_USER=myprox_user
POSTGRES_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>

# ── Redis ───────────────────────────────────────────────────────────
# (no password by default, add requirepass in redis.conf for prod)

# ── Backend API ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://myprox_user:<CHANGE_ME_STRONG_PASSWORD>@postgres:5432/myprox
REDIS_URL=redis://redis:6379

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=<CHANGE_ME_64_CHAR_RANDOM_STRING>
JWT_REFRESH_SECRET=<CHANGE_ME_64_CHAR_RANDOM_STRING>

# Encryption key for Proxmox credentials (exactly 32 chars)
ENCRYPTION_KEY=<CHANGE_ME_EXACTLY_32_CHARS_KEY!>

# Relay
RELAY_URL=wss://relay.myprox.app/agent/connect
API_RELAY_SECRET=<CHANGE_ME_64_CHAR_RANDOM_STRING>

# CORS — comma-separated origins
CORS_ORIGINS=https://myprox.app,https://api.myprox.app

# ── Stripe ──────────────────────────────────────────────────────────
# Get from dashboard.stripe.com > Developers > API keys
STRIPE_SECRET_KEY=sk_live_<YOUR_STRIPE_LIVE_SECRET_KEY>
# Get from dashboard.stripe.com > Developers > Webhooks > your endpoint
STRIPE_WEBHOOK_SECRET=whsec_<YOUR_WEBHOOK_SIGNING_SECRET>
# Get from dashboard.stripe.com > Products > your Premium product > Price ID
STRIPE_PRICE_ID_PREMIUM=price_<YOUR_PRICE_ID>
# URLs after payment
STRIPE_SUCCESS_URL=https://myprox.app/pricing?success=1
STRIPE_CANCEL_URL=https://myprox.app/pricing

# ── Cloudflare Tunnel ───────────────────────────────────────────────
# Get from dash.cloudflare.com > Zero Trust > Networks > Tunnels
# Create tunnel, copy the token shown during setup
CLOUDFLARE_TUNNEL_TOKEN=eyJ<YOUR_CLOUDFLARE_TUNNEL_TOKEN>

# ── Relay service ───────────────────────────────────────────────────
JWT_SECRET=${JWT_SECRET}
API_RELAY_SECRET=${API_RELAY_SECRET}
