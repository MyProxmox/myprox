# Database
DATABASE_URL=postgresql://myprox_user:devpass123@postgres:5432/myprox
POSTGRES_DB=myprox
POSTGRES_USER=myprox_user
POSTGRES_PASSWORD=devpass123

# JWT (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars!!
